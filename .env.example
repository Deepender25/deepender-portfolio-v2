# ── Gemini AI ────────────────────────────────────────────────
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ── App URL ──────────────────────────────────────────────────
APP_URL="MY_APP_URL"

# ── Nodemailer / Contact Form ────────────────────────────────
# The Gmail account you send FROM (must have an App Password generated)
SENDER_EMAIL="your.sender.gmail@gmail.com"

# 16-character Gmail App Password (NOT your regular Gmail password)
# How to get one: Google Account → Security → 2-Step Verification → App Passwords
SENDER_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Your personal email where you RECEIVE the contact form messages
RECEIVER_EMAIL="yadavdeepender65@gmail.com"

# Port the Express API server runs on (default: 3001)
SERVER_PORT=3001

# Background Type (0 = Ethereal Shadow, 1 = Waves, 0-1 = Cycles every X min)
# Set the cycle duration in minutes (defaults to 10 if not set)
VITE_BACKGROUND_CYCLE_MINUTES=10
VITE_BACKGROUND_TYPE=0
